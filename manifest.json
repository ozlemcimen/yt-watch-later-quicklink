{
    "manifest_version": 3,
    "name": "YouTube Watch Later Quick Link",
    "version": "1.0",
    "description": "Adds quick access 'Watch Later' and 'History' buttons to the YouTube mini sidebar.",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "action": {
        "default_title": "YouTube Watch Later Quick Link",
        "default_popup": "",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}